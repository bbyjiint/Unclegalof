generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  SALES
  REPAIRS
}

enum Status {
  paid
  pending
  deposit
}

enum DeliveryMethod {
  selfpickup
  delivery
}

enum PromotionAmountType {
  fixed
  percent
}

enum InventoryDirection {
  IN
  OUT
}

enum PipelineStatus {
  planned
  ordered
  transit
  arrived
}

enum PipelinePriority {
  normal
  urgent
  low
}

enum StoredFilePurpose {
  PAYMENT_SLIP
  REPAIR_IMAGE
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  fullName              String
  username                 String                 @unique
  passwordHash          String
  phone                 String?
  role                  UserRole               @default(SALES)
  /// Legacy tenant-scope column. Nullable for all roles in current role model.
  ownerId               String?                @db.Uuid
  baseSalary            Int?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  createdSales          SaleRecord[]
  createdSalesOrders    SalesOrder[]           @relation("SalesOrderCreatedBy")
  /// Sales belonging to this user as tenant owner (see SaleRecord.ownerId).
  salesAsTenantOwner    SaleRecord[]           @relation("SaleTenant")
  salesOrdersAsTenantOwner SalesOrder[]        @relation("SalesOrderTenant")
  repairRecordsReported RepairRecord[]
  saleCommissions       SaleRecordCommission[]
  payrollRecords        PayrollRecord[]
  inventoryMovements    InventoryMovement[]
  uploadedFiles         R2File[]
  paymentBatchesCreated PaymentBatch[]
}

model DeskItem {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @unique
  onsitePrice   Int
  deliveryPrice Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  saleRecords   SaleRecord[]
  salesOrderLines SalesOrderLine[]
  repairRecords RepairRecord[]
  inventoryLots InventoryLot[]
  inventoryMovements InventoryMovement[]
  pipelineItems PipelineItem[]
  /// One row per stock receipt with a recorded ต้นทุน/หน่วย — used for simple average cost.
  costLogs      DeskItemCostLog[]
}

model DeliveryFee {
  range       Int          @id
  cost        Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  saleRecords SaleRecord[]
  salesOrders SalesOrder[]
}

model Promotion {
  id          String               @id @default(uuid()) @db.Uuid
  name        String               @unique
  amountType  PromotionAmountType  @default(fixed)
  amount      Int                  @default(0)
  isActive    Boolean              @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  saleRecords SaleRecord[]
  salesOrders SalesOrder[]
}

model SalesOrder {
  id                   String            @id @default(uuid()) @db.Uuid
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  ownerId              String            @db.Uuid
  saleDate             DateTime
  orderNumber          String            @unique
  status               Status            @default(pending)
  appliedPromotion     String?           @db.Uuid
  promoDiscountTotal   Int               @default(0)
  manualDiscount       Int               @default(0)
  manualDiscountReason String?
  subtotal             Int               @default(0)
  grandTotal           Int               @default(0)
  deliveryType         DeliveryMethod    @default(selfpickup)
  deliveryCompletedAt  DateTime?
  deliveryRange        Int?
  workerFee            Int               @default(0)
  workerFeeType        String?
  customerName         String?
  customerPhone        String?           @db.Text
  deliveryAddress      String?           @db.Text
  remarks              String?
  paymentSlipImage     String?           @db.Text
  slipViewedAt         DateTime?
  paidAt               DateTime?
  createdByUserId      String?           @db.Uuid
  createdBy            User?             @relation("SalesOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deliveryFee          DeliveryFee?      @relation(fields: [deliveryRange], references: [range])
  promotion            Promotion?        @relation(fields: [appliedPromotion], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tenantOwner          User              @relation("SalesOrderTenant", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lines                SalesOrderLine[]
  saleRecords          SaleRecord[]      @relation("SalesOrderSaleRecords")

  @@index([saleDate])
  @@index([appliedPromotion])
  @@index([deliveryRange])
  @@index([createdByUserId])
}

model SalesOrderLine {
  id                  String       @id @default(uuid()) @db.Uuid
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  salesOrderId        String       @db.Uuid
  lineNumber          Int
  deskItemId          String       @db.Uuid
  quantity            Int          @default(1)
  unitPrice           Int
  promoDiscount       Int          @default(0)
  manualDiscount      Int          @default(0)
  amount              Int
  avgUnitCostSnapshot Int          @default(0)
  cogsTotal           Int          @default(0)
  grossProfit         Int          @default(0)
  deskItem            DeskItem     @relation(fields: [deskItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  salesOrder          SalesOrder   @relation(fields: [salesOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([salesOrderId])
  @@index([deskItemId])
  @@unique([salesOrderId, lineNumber])
}

model SaleRecord {
  id                   String                 @id @default(uuid()) @db.Uuid
  createdAt            DateTime               @default(now())
  /// Tenant: the OWNER user id this order belongs to.
  ownerId              String                 @db.Uuid
  saleDate             DateTime
  orderNumber          String                 @unique
  deskType             String                 @db.Uuid
  quantity             Int                    @default(1)
  unitPrice            Int
  promoDiscount        Int                    @default(0)
  manualDiscount       Int                    @default(0)
  manualDiscountReason String?
  status               Status                 @default(pending)
  appliedPromotion     String?                @db.Uuid
  amount               Int
  /// Simple average of recorded purchase ต้นทุน/หน่วย for this SKU at sale time.
  avgUnitCostSnapshot  Int                    @default(0)
  /// quantity * avgUnitCostSnapshot — COGS for this line.
  cogsTotal            Int                    @default(0)
  /// (amount - workerFee) - cogsTotal — product gross profit snapshot.
  grossProfit          Int                    @default(0)
  deliveryType         DeliveryMethod         @default(selfpickup)
  /// Set when driver marks home delivery as done (hidden from pending delivery queue).
  deliveryCompletedAt  DateTime?
  deliveryRange        Int?
  workerFee            Int                    @default(0)
  workerFeeType        String?
  customerName         String?
  /// Contact phone for delivery (optional; recommended for จัดส่ง).
  customerPhone        String?                @db.Text
  deliveryAddress      String?                @db.Text
  remarks              String?
  paymentSlipImage     String?                @db.Text
  slipViewedAt         DateTime?
  paidAt               DateTime?
  paymentBatchId       String?                @db.Uuid
  salesOrderId         String?                @db.Uuid
  /// User who created this sale row (audit / accountability); not cleared on shared edits.
  createdByUserId      String?                @db.Uuid
  deskItem             DeskItem               @relation(fields: [deskType], references: [id], onDelete: Restrict, onUpdate: Cascade)
  deliveryFee          DeliveryFee?           @relation(fields: [deliveryRange], references: [range])
  promotion            Promotion?             @relation(fields: [appliedPromotion], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy            User?                  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  paymentBatch         PaymentBatch?          @relation(fields: [paymentBatchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  salesOrder           SalesOrder?            @relation("SalesOrderSaleRecords", fields: [salesOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  commissions          SaleRecordCommission[]
  tenantOwner          User                   @relation("SaleTenant", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([saleDate])
  @@index([deskType])
  @@index([appliedPromotion])
  @@index([deliveryRange])
  @@index([createdByUserId])
  @@index([paymentBatchId])
  @@index([salesOrderId])
}

model PaymentBatch {
  id               String       @id @default(uuid()) @db.Uuid
  batchNumber      String       @unique
  totalAmount      Int
  transferAmount   Int?
  paymentSlipImage String       @db.Text
  note             String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  createdByUserId  String?      @db.Uuid
  createdBy        User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  saleRecords      SaleRecord[]

  @@index([createdAt])
  @@index([createdByUserId])
}

/// Sample of ต้นทุน/หน่วย each time stock is received (batch). Average of these = sale COGS basis.
model DeskItemCostLog {
  id          String   @id @default(uuid()) @db.Uuid
  deskItemId  String   @db.Uuid
  costPerUnit Int
  createdAt   DateTime @default(now())
  deskItem    DeskItem @relation(fields: [deskItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([deskItemId])
}

model RepairRecord {
  id          String       @id @default(uuid()) @db.Uuid
  deskItemId   String       @db.Uuid
  reportedBy   String       @db.Uuid
  createdAt    DateTime     @default(now())
  reportDate   DateTime
  quantity     Int          @default(1)
  size         String?
  color        String?
  description  String
  kind         String       @default("repair")
  status       String       @default("open")
  amount       Int
  /// Public image URLs stored in Cloudflare R2.
  images       Json         @default("[]")
  deskItem     DeskItem     @relation(fields: [deskItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reporter     User         @relation(fields: [reportedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([deskItemId])
  @@index([reportedBy])
}

model SaleRecordCommission {
  id           String       @id @default(uuid()) @db.Uuid
  saleRecordId String       @db.Uuid
  userId       String       @db.Uuid
  amount       Int
  remarks      String?
  createdAt    DateTime     @default(now())
  saleRecord   SaleRecord   @relation(fields: [saleRecordId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  worker       User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([saleRecordId])
  @@index([userId])
  @@index([userId, createdAt])
}

model PayrollRecord {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  month           Int
  year            Int
  baseSalary      Int
  commissionTotal Int          @default(0)
  bonus           Int?
  deduction       Int?
  totalPaid       Int
  paidAt          DateTime?
  remarks         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  worker          User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
  @@index([year, month])
}

/// Stock received in batches; remainingQty supports future OUT movements.
model InventoryLot {
  id             String   @id @default(uuid()) @db.Uuid
  deskItemId     String   @db.Uuid
  qty            Int
  remainingQty   Int
  costPerUnit    Int      @default(0)
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deskItem       DeskItem @relation(fields: [deskItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  movements      InventoryMovement[]

  @@index([deskItemId])
  @@index([createdAt])
}

model InventoryMovement {
  id              String             @id @default(uuid()) @db.Uuid
  deskItemId      String             @db.Uuid
  inventoryLotId  String?            @db.Uuid
  direction       InventoryDirection
  qty             Int
  note            String?
  createdAt       DateTime           @default(now())
  createdByUserId String?            @db.Uuid
  deskItem        DeskItem           @relation(fields: [deskItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lot             InventoryLot?      @relation(fields: [inventoryLotId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy       User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([deskItemId])
  @@index([createdAt])
  @@index([inventoryLotId])
}

/// Incoming supply / orders not yet in stock (owner pipeline).
model PipelineItem {
  id            String           @id @default(uuid()) @db.Uuid
  deskItemId    String           @db.Uuid
  qty           Int
  costEst       Int              @default(0)
  expectedDate  DateTime?
  note          String?
  status        PipelineStatus   @default(planned)
  priority      PipelinePriority @default(normal)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deskItem      DeskItem         @relation(fields: [deskItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([deskItemId])
  @@index([status])
  @@index([expectedDate])
}

model R2File {
  id               String            @id @default(uuid()) @db.Uuid
  objectKey        String            @unique
  fileUrl          String
  bucketName       String
  originalFileName String
  contentType      String
  fileSize         Int
  purpose          StoredFilePurpose
  uploadedByUserId String            @db.Uuid
  createdAt        DateTime          @default(now())
  uploadedBy       User              @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([uploadedByUserId])
  @@index([purpose])
  @@index([createdAt])
}
