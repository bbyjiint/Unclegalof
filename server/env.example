# Prisma (PostgreSQL). For local Postgres without pooling, set DIRECT_URL the same as DATABASE_URL.
DATABASE_URL="postgresql://tolopburi:tolopburi_dev@localhost:5433/tolopburi"
DIRECT_URL="postgresql://tolopburi:tolopburi_dev@localhost:5433/tolopburi"

PORT=4001
CLIENT_ORIGIN="http://localhost:5173"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
JWT_EXPIRES_IN="7d"
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-r2-bucket-name"
R2_PUBLIC_BASE_URL="https://your-bucket-public-url.r2.dev"
